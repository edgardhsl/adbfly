{
  "name": "adbfly",
  "version": "0.1.0",
  "description": "Android Device Explorer - Browse and manage device data via ADB",
  "author": "EdgarHS <edgardhsl@gmail.com>",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/edgardhsl/adbfly"
  },
  "scripts": {
    "dev": "next dev",
    "dev:tauri": "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next dev --webpack --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "design:audit": "impeccable detect src/app/page.tsx src/app/globals.css src/components/ui",
    "design:audit:fast": "impeccable detect --fast src/",
    "design:live": "impeccable live",
    "tauri": "node scripts/tauri-runner.js",
    "tauri:dev": "node scripts/tauri-runner.js dev",
    "tauri:build": "node scripts/tauri-runner.js build",
    "tauri:icon": "tauri icon public/images/logo.webp"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
