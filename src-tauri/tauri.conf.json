{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADB Device Explorer",
  "version": "0.1.0",
  "identifier": "com.adbdeviceexplorer.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "ADB Device Explorer",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}